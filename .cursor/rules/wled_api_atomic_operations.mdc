        on: true  // ✅ Atomic operation
    )
    devices[index].isOn = true  // ✅ State sync
}
```

### ❌ Wrong: Separate Calls
```swift
// ❌ DON'T: Separate calls cause color flash
await updateDeviceState(device) { ... isOn = true }
await applyGradientStopsAcrossStrip(...)  // Color flash!
```

