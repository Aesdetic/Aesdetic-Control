## Real-World Examples

### ✅ Correct: Power-On with Gradient
```swift
if isTurningOn, let persistedStops = gradientStops(for: device.id), !persistedStops.isEmpty {
    markUserInteraction(device.id)
    await applyGradientStopsAcrossStrip(
        device,
        stops: persistedStops,
        brightness: device.brightness,
        on: true  // ✅ Atomic operation
    )
    devices[index].isOn = true  // ✅ State sync
}
```

### ✅ Correct: Brightness Change with Gradient
```swift
if brightness == 0 {
    await updateDeviceState(device) { ... isOn = false, brightness = 0 }
    return
}

if hasPersistedGradient {
    markUserInteraction(device.id)
    await applyGradientStopsAcrossStrip(
